# -------------------------------------------------
# TRACE — Environment Configuration
# Copy to .env and fill in values
# -------------------------------------------------

# --- Database (PostgreSQL) ---
# Three separate connections for three-vault isolation.
# Each role has minimal privileges scoped to its own schema.
DATABASE_URL_OPS=postgresql://trace_ops:PASSWORD@127.0.0.1:5432/trace
DATABASE_URL_IDENT=postgresql://trace_ident:PASSWORD@127.0.0.1:5432/trace
DATABASE_URL_EVIDENCE=postgresql://trace_evidence:PASSWORD@127.0.0.1:5432/trace

# --- Server ---
PORT=3100
HOST=0.0.0.0
NODE_ENV=production

# --- Auth ---
# Magic link sender (SMTP or Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAGIC_LINK_FROM=noreply@trace.local

# TOTP encryption key (for operator/admin 2FA secrets at rest)
TOTP_ENCRYPTION_KEY=

# Vault B field-level encryption key (AES-256, 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_B_ENCRYPTION_KEY=

# Session signing secret
SESSION_SECRET=

# --- Evidence ---
# Vault C encryption key (AES-256, 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EVIDENCE_ENCRYPTION_KEY=

# Local evidence storage path
EVIDENCE_STORAGE_PATH=./data/evidence

# --- Notifications ---
# Web Push VAPID keys (generate with npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@trace.local
