# -------------------------------------------------
# TRACE — Environment Configuration
# Copy to .env and fill in values
# -------------------------------------------------

# --- Database (PostgreSQL) ---
# Vault A: operational data (pseudonymous sightings, vehicles, actors)
DATABASE_URL_OPS=postgresql://trace_ops:PASSWORD@localhost:5432/trace?schema=ops

# Vault B: identity data (reporter real identities — separate key)
DATABASE_URL_IDENT=postgresql://trace_ident:PASSWORD@localhost:5432/trace?schema=ident

# Vault C: evidence locker (write-once, append-only)
DATABASE_URL_EVIDENCE=postgresql://trace_evidence:PASSWORD@localhost:5432/trace?schema=evidence

# --- Server ---
PORT=3100
HOST=0.0.0.0
NODE_ENV=production

# --- Auth ---
# Magic link sender (SMTP or Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAGIC_LINK_FROM=noreply@trace.local

# TOTP encryption key (for operator/admin 2FA secrets at rest)
TOTP_ENCRYPTION_KEY=

# Vault B field-level encryption key (AES-256, 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_B_ENCRYPTION_KEY=

# Session signing secret
SESSION_SECRET=

# --- Evidence ---
# Vault C encryption key (AES-256, 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EVIDENCE_ENCRYPTION_KEY=

# Local evidence storage path
EVIDENCE_STORAGE_PATH=./data/evidence

# --- Notifications ---
# Web Push VAPID keys (generate with npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@trace.local
